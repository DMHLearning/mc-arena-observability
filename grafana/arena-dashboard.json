          "expr": "rate(arena_exceptions_total{server=~\"$server\"}[5m])",
          "legendFormat": "{{server}} {{module}}"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "arena_error_log_rate{server=~\"$server\"}",
          "legendFormat": "{{server}} Error Log Rate"
        }
      ],
      "title": "Exceptions & Error Rate",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 62 },
      "id": 106,
      "title": "Health State History",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 60, "lineWidth": 1, "showPoints": "never", "stacking": { "mode": "normal" } },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 63 },
      "id": 19,
      "options": { "legend": { "calcs": [], "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "arena_homeostasis_state{server=~\"$server\", state=\"HEALTHY\"}",
          "legendFormat": "{{server}} HEALTHY"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "arena_homeostasis_state{server=~\"$server\", state=\"DEGRADED\"}",
          "legendFormat": "{{server}} DEGRADED"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "arena_homeostasis_state{server=~\"$server\", state=\"CRITICAL\"}",
          "legendFormat": "{{server}} CRITICAL"
