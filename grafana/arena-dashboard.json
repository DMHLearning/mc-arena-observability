          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "rate(arena_incident_raised_total{server=~\"$server\"}[5m])",
          "legendFormat": "{{server}} {{code}}"
        }
      ],
      "title": "Incidents Raised (rate)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 10, "lineWidth": 2, "showPoints": "never" }, "unit": "ops" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 54 },
      "id": 18,
      "options": { "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
